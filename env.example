# DayTrack Telegram Bot - Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================================================
# REQUIRED
# ============================================================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# DATABASE (choose one)
# ============================================================================

# Option 1: Turso Cloud (RECOMMENDED for deployment — free, persistent)
# Sign up at https://turso.tech, create a database, get these values:
#   turso db show --url <db-name>
#   turso db tokens create <db-name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Option 2: Local SQLite (for development only — data lost on redeploy)
SQLITE_DB_PATH=daytrack.db

# ============================================================================
# OPTIONAL
# ============================================================================

GROQ_MODEL=llama-3.1-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.7
LOG_LEVEL=INFO
